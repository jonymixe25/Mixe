# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=https://ais-dev-pv36nrtuj5a2gjy2v7siug-317869607678.us-west2.run.app

# LiveKit Configuration
# Configure these in the Secrets panel in AI Studio
LIVEKIT_URL=wss://new-app-6tu2ilh8.livekit.cloud
LIVEKIT_API_KEY=APIc7VDQEHdtKH5
LIVEKIT_API_SECRET=8oJdsU0MvZm72Tcxnu69SnTpMtJEHqY28rGCB7nfGsH
# Troubleshooting:
# 1. En LiveKit Cloud, usa la 'API Key' de Settings > Keys, NO el 'Project ID'.
# 2. La API Key debe empezar por 'API'.
# 3. La URL debe incluir el protocolo wss://

# Client-side LiveKit URL (prefixed with VITE_)
VITE_LIVEKIT_URL=wss://new-app-6tu2ilh8.livekit.cloud
