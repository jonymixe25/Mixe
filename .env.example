# ============================================================================
# MIXE - Environment Variables Configuration
# ============================================================================

# GEMINI_API_KEY: Optional - Required for Gemini AI API calls
GEMINI_API_KEY=

# APP_URL: The URL where this application is hosted
APP_URL=https://ais-dev-pv36nrtuj5a2gjy2v7siug-317869607678.us-west2.run.app

# ============================================================================
# LIVEKIT CONFIGURATION
# ============================================================================
# LiveKit is used for real-time video/audio streaming
# Get credentials from: https://cloud.livekit.io

# LIVEKIT_URL: The WebSocket URL for LiveKit server
# Format: wss://project-name.livekit.cloud
LIVEKIT_URL=wss://new-app-6tu2ilh8.livekit.cloud

# LIVEKIT_API_KEY: Must start with "API" prefix
# ⚠️  Do NOT use Project ID - use the API Key instead
LIVEKIT_API_KEY=APIc7VDQEHdtKH5

# LIVEKIT_API_SECRET: Secret key for signing access tokens
LIVEKIT_API_SECRET=8oJdsU0MvZm72Tcxnu69SnTpMtJEHqY28rGCB7nfGsH

# Client-side LiveKit URL
VITE_LIVEKIT_URL=wss://new-app-6tu2ilh8.livekit.cloud

# NODE_ENV: Application environment (development or production)
NODE_ENV=development

# ============================================================================
# VALIDATION & TROUBLESHOOTING
# ============================================================================
#
# Required Variables:
#   - APP_URL: Must be a valid URL
#   - LIVEKIT_URL: Must use wss:// or ws://
#   - LIVEKIT_API_KEY: Must start with "API"
#   - LIVEKIT_API_SECRET: Min 20 characters
#   - VITE_LIVEKIT_URL: Must use wss:// or ws://
#
# Troubleshooting:
# 1. "API Key format incorrect" → Use API Key from LiveKit, NOT Project ID
# 2. "Cannot reach server" → Verify LIVEKIT_URL uses wss:// protocol
# 3. "Unauthorized" → Check API Key and Secret match your project
# 4. "Env vars not loading" → File must be named .env (not .env.example)
#
# ============================================================================
