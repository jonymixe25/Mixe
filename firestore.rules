rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "jonyoax95@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if true;
      allow write: if isOwner(uid) || isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if request.auth.token.email == "jonyoax95@gmail.com" || isAdmin();
    }

    match /streams/{streamId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /media/{mediaId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /recordings/{recordingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn();
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /calls/{callId} {
      allow read, write: if isSignedIn();
    }
  }
}

