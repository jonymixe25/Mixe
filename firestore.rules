rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net - Default Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "jonyoax95@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
       return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Collection: Users
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    match /users/{uid} {
      allow read: if true; // Public profiles
      allow create: if isUser(uid) && isValidId(uid) && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if (isUser(uid) || isAdmin()) && 
                    isValidId(uid) &&
                    isValidUser(incoming()) && 
                    (incoming().role == existing().role || isAdmin()) &&
                    incoming().createdAt == existing().createdAt;
    }

    // ===============================================================
    // Collection: Streams
    // ===============================================================
    function isValidStream(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.status in ['live', 'ended'] &&
             data.startedAt is timestamp &&
             data.viewerCount is number &&
             data.likes is number &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('thumbnailUrl' in data) || (data.thumbnailUrl is string && data.thumbnailUrl.size() <= 1000)) &&
             (!('privacy' in data) || (data.privacy in ['public', 'private'])) &&
             (!('latency' in data) || (data.latency in ['normal', 'low'])) &&
             (!('resolution' in data) || (data.resolution in ['720p', '1080p']));
    }

    match /streams/{streamId} {
      allow read: if true; 
      allow create: if isVerified() && isValidId(streamId) && isValidStream(incoming()) && 
                     incoming().startedAt == request.time;
      allow update: if isValidId(streamId) && (
        // Action: Owner/Admin Full Update
        ((isUser(existing().userId) || isAdmin()) && isValidStream(incoming()) && (
          // Prevent restarting ended streams
          existing().status != 'ended' || incoming().status == 'ended' || isAdmin()
        )) ||
        // Action: Viewer Update (Likes/Viewers)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['viewerCount', 'likes']) &&
          (
            ('viewerCount' in incoming().diff(existing()).affectedKeys() && math.abs(incoming().viewerCount - existing().viewerCount) == 1) ||
            ('likes' in incoming().diff(existing()).affectedKeys() && math.abs(incoming().likes - existing().likes) == 1)
          )
        )
      );
      allow delete: if isAdmin() || isUser(existing().userId);

      // Sub-collection: Stream Messages
      match /messages/{messageId} {
        allow read: if true;
        allow create: if isSignedIn() && 
                       isValidId(messageId) &&
                       incoming().userId == request.auth.uid &&
                       incoming().text is string && incoming().text.size() <= 1000 &&
                       incoming().createdAt == request.time;
        allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      }

      // Sub-collection: Join Requests
      match /joinRequests/{requestId} {
        allow read: if isSignedIn() && (request.auth.uid == requestId || request.auth.uid == get(/databases/$(database)/documents/streams/$(streamId)).data.userId || isAdmin());
        allow write: if isSignedIn() && isValidId(requestId) && (
          // Create/Update own request
          (request.auth.uid == requestId && incoming().status in ['pending', 'none']) ||
          // Host accepts/rejects
          (request.auth.uid == get(/databases/$(database)/documents/streams/$(streamId)).data.userId && 
           incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
          isAdmin()
        );
      }

      // Sub-collection: Invitations
      match /invitations/{invitationId} {
        allow read: if isSignedIn() && (request.auth.uid == invitationId.split('_')[1] || request.auth.uid == get(/databases/$(database)/documents/streams/$(streamId)).data.userId || isAdmin() || (resource != null && resource.data.to == request.auth.uid));
        allow create: if isSignedIn() && isValidId(invitationId) && (request.auth.uid == get(/databases/$(database)/documents/streams/$(streamId)).data.userId || isAdmin()) && 
                       incoming().from == request.auth.uid && 
                       incoming().createdAt == request.time;
        allow update: if isSignedIn() && (
          (request.auth.uid == get(/databases/$(database)/documents/streams/$(streamId)).data.userId || isAdmin()) ||
          (existing().to == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'acceptedAt', 'rejectedAt']))
        );
        allow delete: if isSignedIn() && (request.auth.uid == get(/databases/$(database)/documents/streams/$(streamId)).data.userId || isAdmin());
      }
      
      // Signaling subcollections
      match /signaling/{signalingId} {
        allow read, write: if isSignedIn() && isValidId(signalingId) && (request.auth.uid == signalingId || request.auth.uid == get(/databases/$(database)/documents/streams/$(streamId)).data.userId || isAdmin());
      }
      
      match /guestSignaling/{guestId} {
        allow read, write: if isSignedIn() && isValidId(guestId) && (guestId == request.auth.uid || request.auth.uid == get(/databases/$(database)/documents/streams/$(streamId)).data.userId || isAdmin());
      }
    }

    // ===============================================================
    // Collection: News
    // ===============================================================
    match /news/{newsId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(newsId) &&
                     incoming().authorId == request.auth.uid &&
                     incoming().createdAt == request.time;
      allow update: if isAdmin() && 
                     incoming().authorId == existing().authorId &&
                     incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Collection: Settings & Alerts
    // ===============================================================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId);
    }

    match /alerts/{alertId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(alertId);
    }

    // ===============================================================
    // Collection: Media & Recordings
    // ===============================================================
    match /media/{mediaId} {
      allow read: if isSignedIn() && (resource.data.isPublic == true || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(mediaId) && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /recordings/{recordingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(recordingId) && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // ===============================================================
    // Collection: Private Chats & Calls
    // ===============================================================
    match /chats/{chatId} {
      allow read: if isSignedIn() && chatId.matches(".*" + request.auth.uid + ".*");
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && chatId.matches(".*" + request.auth.uid + ".*");
        allow create: if isSignedIn() && isValidId(messageId) && chatId.matches(".*" + request.auth.uid + ".*") && incoming().senderId == request.auth.uid && incoming().createdAt == request.time;
      }
    }

    match /calls/{callId} {
      allow read, write: if isSignedIn() && isValidId(callId) && callId.matches(".*" + request.auth.uid + ".*");
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && callId.matches(".*" + request.auth.uid + ".*");
      }
    }
    
    // User Contacts
    match /users/{uid}/contacts/{contactId} {
      allow read: if isUser(uid) || isAdmin();
      allow create: if isUser(uid) && isValidId(contactId) && incoming().userId == request.auth.uid && incoming().addedAt == request.time;
      allow update: if isUser(uid) && incoming().userId == existing().userId;
      allow delete: if isUser(uid) || isAdmin();
    }
  }
}

