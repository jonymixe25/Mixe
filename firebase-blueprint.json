{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "displayNameLowercase": { "type": "string" },
        "email": { "type": "string" },
        "emailLowercase": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Stream": {
      "title": "Live Stream",
      "description": "Live stream session information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["live", "ended"] },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "viewerCount": { "type": "number" }
      },
      "required": ["userId", "title", "status", "startedAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "User contact/friend relationship",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "contactId": { "type": "string" },
        "contactName": { "type": "string" },
        "contactPhoto": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "contactId"]
    },
    "News": {
      "title": "News Article",
      "description": "News and cultural updates",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId", "createdAt"]
    },
    "Media": {
      "title": "Media Item",
      "description": "Uploaded image or media file metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "url": { "type": "string" },
        "folder": { "type": "string" },
        "fileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "url", "folder", "fileName", "createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "Real-time chat message for a stream",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "createdAt"]
    },
    "PrivateMessage": {
      "title": "Private Message",
      "description": "Direct message between users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/streams/{streamId}": {
      "schema": "Stream",
      "description": "Live stream session documents"
    },
    "/streams/{streamId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages subcollection"
    },
    "/users/{uid}/contacts/{contactId}": {
      "schema": "Contact",
      "description": "User contacts subcollection"
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "News articles collection"
    },
    "/media/{mediaId}": {
      "schema": "Media",
      "description": "Media items collection"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "PrivateMessage",
      "description": "Private messages subcollection"
    }
  }
}
